generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

enum UserRole {
  ADMIN
  EDITOR
  AUTHOR
}

enum ContentType {
  ARTICLE
  LANDING_PAGE
  SERVICE_PAGE
  CASE_STUDY
  GLOSSARY
  FAQ
  COMPARISON
  PILLAR_PAGE
  CATEGORY_HUB
  CUSTOM
}

enum ContentStatus {
  IDEA
  DRAFT
  AI_ENRICHED
  REVIEW
  APPROVED
  SCHEDULED
  PUBLISHED
  ARCHIVED
}

enum AIJobStatus {
  QUEUED
  RUNNING
  COMPLETED
  FAILED
}

model Site {
  id        String   @id @default(cuid())
  name      String
  domain    String?  @unique
  subdomain String?
  locale    String   @default("pt-BR")
  theme     String?
  settings  String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  contents   Content[]
  categories Category[]
  tags       Tag[]
  redirects  Redirect[]
}

model User {
  id        String   @id @default(cuid())
  name      String
  email     String   @unique
  password  String?
  role      UserRole @default(EDITOR)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  contents  Content[]
  revisions ContentRevision[]
}

model Author {
  id        String   @id @default(cuid())
  name      String
  slug      String   @unique
  bio       String?
  avatarUrl String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  contents Content[]
}

model Category {
  id          String   @id @default(cuid())
  siteId      String
  name        String
  slug        String
  description String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  site     Site      @relation(fields: [siteId], references: [id], onDelete: Cascade)
  contents Content[]

  @@unique([siteId, slug])
}

model Tag {
  id        String   @id @default(cuid())
  siteId    String
  name      String
  slug      String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  site     Site         @relation(fields: [siteId], references: [id], onDelete: Cascade)
  contents ContentTag[]

  @@unique([siteId, slug])
}

model Content {
  id        String        @id @default(cuid())
  siteId    String
  type      ContentType
  status    ContentStatus @default(DRAFT)

  title       String
  slug        String
  excerpt     String?
  content     String?
  readingTime Int?

  canonicalUrl String?
  publishedAt  DateTime?
  scheduledAt  DateTime?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  parentId String?
  parent   Content?  @relation("ContentHierarchy", fields: [parentId], references: [id])
  children Content[] @relation("ContentHierarchy")

  site Site @relation(fields: [siteId], references: [id], onDelete: Cascade)

  authorId String?
  author   Author? @relation(fields: [authorId], references: [id])

  categoryId String?
  category   Category? @relation(fields: [categoryId], references: [id])

  createdById String?
  createdBy   User? @relation(fields: [createdById], references: [id])

  featuredImageId String?
  featuredImage   Media? @relation("ContentFeaturedImage", fields: [featuredImageId], references: [id])

  tags       ContentTag[]
  seo        ContentSEO?
  brief      ContentBrief?
  revisions  ContentRevision[]
  analytics  ContentAnalytics?
  calendar   EditorialCalendar?
  aiJobs     AIJob[]
  mediaLinks ContentMedia[]

  @@unique([siteId, slug])
}

model ContentTag {
  contentId String
  tagId     String

  content Content @relation(fields: [contentId], references: [id], onDelete: Cascade)
  tag     Tag     @relation(fields: [tagId], references: [id], onDelete: Cascade)

  @@id([contentId, tagId])
}

model ContentMedia {
  contentId String
  mediaId   String
  role      String?
  sortOrder Int     @default(0)

  content Content @relation(fields: [contentId], references: [id], onDelete: Cascade)
  media   Media   @relation(fields: [mediaId], references: [id], onDelete: Cascade)

  @@id([contentId, mediaId])
}

model ContentSEO {
  id          String @id @default(cuid())
  contentId   String @unique

  metaTitle       String?
  metaDescription String?
  focusKeyword    String?
  secondaryKeywords String?
  canonicalUrl    String?
  robots          String?
  schemaJson      String?

  ogTitle       String?
  ogDescription String?
  ogImageUrl    String?

  readabilityScore   Int?
  semanticScore      Int?
  internalLinkScore  Int?
  freshnessScore     Int?
  overallScore       Int?

  noIndex Boolean @default(false)

  content Content @relation(fields: [contentId], references: [id], onDelete: Cascade)
}

model ContentBrief {
  id        String @id @default(cuid())
  contentId String @unique

  keyword       String?
  intent        String?
  persona       String?
  objective     String?
  funnelStage   String?
  competitors   String?
  outline       String?
  internalLinks String?
  references    String?
  toneOfVoice   String?
  cta           String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  content Content @relation(fields: [contentId], references: [id], onDelete: Cascade)
}

model ContentRevision {
  id        String   @id @default(cuid())
  contentId String
  userId    String?

  title   String
  content String?
  notes   String?
  createdAt DateTime @default(now())

  contentRef Content @relation(fields: [contentId], references: [id], onDelete: Cascade)
  user       User?   @relation(fields: [userId], references: [id])
}

model ContentAnalytics {
  id        String @id @default(cuid())
  contentId String @unique

  views       Int @default(0)
  sessions    Int @default(0)
  avgTime     Int @default(0)
  bounceRate  Float?
  ctr         Float?
  impressions Int @default(0)
  clicks      Int @default(0)
  position    Float?
  lastSync    DateTime?

  content Content @relation(fields: [contentId], references: [id], onDelete: Cascade)
}

model EditorialCalendar {
  id        String @id @default(cuid())
  contentId String @unique

  plannedDate   DateTime?
  scheduledDate DateTime?
  priority      String?
  campaign      String?
  owner         String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  content Content @relation(fields: [contentId], references: [id], onDelete: Cascade)
}

model Media {
  id          String   @id @default(cuid())
  url         String
  storageKey  String?
  filename    String?
  alt         String?
  caption     String?
  credit      String?
  source      String?
  mimeType    String?
  size        Int?
  width       Int?
  height      Int?
  format      String?
  blurDataUrl String?
  folderId    String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  folder   MediaFolder?   @relation(fields: [folderId], references: [id])
  variants MediaVariant[]
  ai       MediaAI?

  featuredIn Content[]      @relation("ContentFeaturedImage")
  contentLinks ContentMedia[]
}

model MediaFolder {
  id        String   @id @default(cuid())
  name      String
  slug      String   @unique
  parentId  String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  parent   MediaFolder?  @relation("MediaFolderHierarchy", fields: [parentId], references: [id])
  children MediaFolder[] @relation("MediaFolderHierarchy")
  media    Media[]
}

model MediaVariant {
  id        String   @id @default(cuid())
  mediaId   String
  url       String
  type      String
  width     Int?
  height    Int?
  size      Int?
  format    String?
  createdAt DateTime @default(now())

  media Media @relation(fields: [mediaId], references: [id], onDelete: Cascade)
}

model MediaAI {
  id              String   @id @default(cuid())
  mediaId          String   @unique
  suggestedAlt     String?
  suggestedCaption String?
  detectedContext  String?
  seoKeywords      String?
  generatedBy      String?
  createdAt        DateTime @default(now())

  media Media @relation(fields: [mediaId], references: [id], onDelete: Cascade)
}

model AIJob {
  id        String      @id @default(cuid())
  contentId String?
  type      String
  status    AIJobStatus @default(QUEUED)

  model        String?
  prompt       String
  response     String?
  error        String?
  tokensInput  Int?
  tokensOutput Int?
  cost         Float?

  startedAt  DateTime?
  finishedAt DateTime?
  createdAt  DateTime @default(now())

  content Content? @relation(fields: [contentId], references: [id], onDelete: SetNull)
}

model Redirect {
  id        String   @id @default(cuid())
  siteId    String?
  fromPath  String
  toPath    String
  statusCode Int     @default(301)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  site Site? @relation(fields: [siteId], references: [id], onDelete: Cascade)

  @@unique([siteId, fromPath])
}